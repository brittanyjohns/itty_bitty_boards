  "permissions": {
    "allow": [
      "Bash(claude mcp *)",
      "Read(//Users/brittanyjohns/.claude/**)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(python3 -c ' *)",
      "Bash(python3 -c \"import json,sys,base64; d=json.load\\(sys.stdin\\); print\\(base64.b64decode\\(d['content']\\).decode\\(\\)\\)\")",
      "Bash(gh issue *)",
      "Bash(bundle exec *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Read(//Users/brittanyjohns/Projects/speakanyway/**)",
      "WebFetch(domain:mcp.stripe.com)",
      "WebFetch(domain:stripe.com)",
      "WebFetch(domain:docs.stripe.com)",
      "Bash(git checkout *)",
      "Bash(git commit -m 'Remove HTML views and controllers — convert to API-only architecture *)",
      "Bash(bin/rails generate *)",
      "Bash(grep -n \"namespace :admin\\\\|devise_for\\\\|mount\\\\|get .dashboard\\\\|end$\" /Users/brittanyjohns/Projects/speakanyway/itty_bitty_boards/config/routes.rb)",
      "Bash(bin/rails db:migrate)",
      "Bash(bin/rails routes *)",
      "Bash(bin/rails runner *)",
      "Skill(claude-api)",
      "Skill(claude-api:*)",
      "Bash(grep -v \"^$\")"
    ],
    "additionalDirectories": [
      "/Users/brittanyjohns/.claude",
      "/Users/brittanyjohns/Projects/speakanyway"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bundle exec rspec",
            "statusMessage": "Running RSpec tests before commit..."
          },
          {
            "type": "command",
            "command": "bundle exec rubocop",
            "statusMessage": "Running rubocop before commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | grep -q Gemfile && bundle install || true",
            "statusMessage": "Installing dependencies if Gemfile changed..."
          },
          {
            "type": "command",
            "command": "bundle exec rubocop --format quiet $CLAUDE_FILE_PATHS 2>&1 || true"
          }
        ]
      }
    ]
  }
}
