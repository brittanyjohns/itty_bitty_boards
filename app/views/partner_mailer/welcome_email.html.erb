<!DOCTYPE html>

<html>
  <head>
    <meta charset="UTF-8" />
    <title><%= t("partner_mailer.welcome_email.title") %></title>
  </head>
  <body style="margin:0; padding:0; background-color:#f7f7fb; font-family: Arial, Helvetica, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f7f7fb; padding:20px;">
      <tr>
            <td align="center">
            <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius:8px; padding:24px;">
                <tr>
                <td style="color:#333333; font-size:16px; line-height:1.5;">
                <p><%= t("partner_mailer.welcome_email.greeting_html", name: @user.name).html_safe %></p>

                <p><%= t("partner_mailer.welcome_email.intro_html").html_safe %></p>

                <p><%= t("partner_mailer.welcome_email.signin_intro") %></p>
                <p>
                  <a href="<%= @sign_in_url %>" style="color:#6c63ff; text-decoration:none;"><%= t("partner_mailer.welcome_email.signin_link") %></a>
                </p>

                <p><strong><%= t("partner_mailer.welcome_email.youre_in") %></strong></p>

                <hr style="border:none; border-top:1px solid #eeeeee; margin:24px 0;" />

                <h3><%= t("partner_mailer.welcome_email.step1_heading") %></h3>
                <p><%= t("partner_mailer.welcome_email.step1_body") %></p>

                <hr style="border:none; border-top:1px solid #eeeeee; margin:24px 0;" />

                <h3><%= t("partner_mailer.welcome_email.portal_heading") %></h3>
                <p><%= t("partner_mailer.welcome_email.portal_body") %></p>
                <p style="text-align:center; margin:24px 0;">
                <a href="<%= @partner_portal_url %>" style="background-color:#2abed1; color:#ffffff; text-decoration:none; padding:14px 22px; border-radius:6px; display:inline-block; font-weight:bold;" target="_blank" rel="noopener">
                    <%= t("partner_mailer.welcome_email.portal_cta") %>
                </a>
                </p>

                <hr style="border:none; border-top:1px solid #eeeeee; margin:24px 0;" />

                <h3><%= t("partner_mailer.welcome_email.expect_heading") %></h3>
                <p><%= t("partner_mailer.welcome_email.expect_intro_html", start_date: @start_date.strftime("%B %d, %Y"), end_date: @end_date.strftime("%B %d, %Y")).html_safe %></p>
                <ul>
                <li><%= t("partner_mailer.welcome_email.expect_item_1") %></li>
                <li><%= t("partner_mailer.welcome_email.expect_item_2") %></li>
                <li><%= t("partner_mailer.welcome_email.expect_item_3") %></li>
                </ul>
                <p><%= t("partner_mailer.welcome_email.expect_outro") %></p>

                <hr style="border:none; border-top:1px solid #eeeeee; margin:24px 0;" />

                <p><%= t("partner_mailer.welcome_email.note_html").html_safe %></p>

                <p><%= t("partner_mailer.welcome_email.voice_html").html_safe %></p>

                <p><%= t("partner_mailer.welcome_email.thanks") %></p>

                <p style="margin-top:32px;">
                💜<br />
                <strong><%= t("partner_mailer.welcome_email.signature") %></strong>
                </p>

            </td>
                </tr>
            </table>
            </td>
        </tr>
    </table>
  </body>
</html>
