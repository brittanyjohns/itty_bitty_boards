<% unless @hide_header %>
  <div class="header">
    <div class="header-inner">
      <div class="logo">
        <% if @logo.present? %>
          <img alt="SpeakAnyWay Logo" src="data:image/png;base64,<%= @logo %>">
        <% end %>
      </div>

      <div class="header-copy">
        <p class="board-title">
          <strong><%= @board_title %></strong>
        </p>

        <p class="board-subtitle">
          Created with SpeakAnyWay AAC
        </p>
        <% if @board_expires_at %>
          <div class="unclaimed-message">
          <p class="board-subtitle" style="color: #ff0000; font-weight: bold;">
            This board is unclaimed and will expire on <%= @board_expires_at.strftime("%B %d, %Y  at %l:%M %p") %> if not claimed. Please claim this board to keep it and edit it online.
          </p>
          </div>
        <% end %>

        <div class="board-link">
          Scan the code or visit
          <a href="<%= @qr_target_url %>" target="_blank" rel="noopener noreferrer">
            <%= @qr_target_url %>
          </a>
          for the full interactive version of this board. 
        </div>
      </div>

      <div class="qr-small">
        <img src="<%= @qr_data_url %>" alt="QR code">
      </div>
    </div>
  </div>
<% end %>

<div class="board-wrap">
  <div
    class="board-sizer"
    style="width:<%= @board_render_width_mm %>mm; height:<%= @board_render_height_mm %>mm;"
  >
    <div
      class="board-grid"
      style="
        grid-template-columns: repeat(<%= @columns %>, 1fr);
        grid-template-rows: repeat(<%= @rows %>, 1fr);
      "
    >
      <% @tiles.each do |t| %>
        <% bg_color = @hide_colors ? "" : (t["bg_color"] || "black") %>

        <% col_start = t["x"].to_i + 1 %>
        <% row_start = t["y"].to_i + 1 %>
        <% col_span = t["w"].to_i %>
        <% row_span = t["h"].to_i %>

        <div
          class="tile"
          style="
            background-color:<%= bg_color.presence || "#ffffff" %>;
            grid-column:<%= col_start %> / span <%= col_span %>;
            grid-row:<%= row_start %> / span <%= row_span %>;
          "
        >
          <div class="tile-media">
            <% if t["image_url"].present? %>
              <img src="<%= t["image_url"] %>" alt="<%= t["label"] %>">
            <% else %>
              <div class="tile-placeholder">
                <%= t["label"] %>
              </div>
            <% end %>
          </div>

          <div
            class="label <%= bg_color %>"
            style="
              font-weight:<%= @hide_colors ? "normal" : "bold" %>;
              background-color:<%= bg_color.presence || "#f7f7f7" %>;
            "
          >
            <%= t["label"] %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>