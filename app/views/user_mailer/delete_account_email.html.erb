<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title><%= t("user_mailer.delete_account_email.header_subtitle") %></title>
  </head>
  <body style="margin:0; padding:0; background:#f6f7f9; font-family: Arial, Helvetica, sans-serif;">
    <!-- app/views/user_mailer/delete_account_email.html.erb -->

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:0;padding:0;background:#f6f7fb;">
  <tr>
    <td align="center" style="padding:24px 12px;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="width:600px;max-width:600px;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e7e7ef;">
        <!-- Header -->
        <tr>
          <td style="padding:22px 24px;background:#0f172a;">
            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:18px;line-height:24px;font-weight:700;color:#ffffff;">
              <%= t("user_mailer.delete_account_email.header_brand") %>
            </div>
            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:13px;line-height:18px;color:#cbd5e1;margin-top:4px;">
              <%= t("user_mailer.delete_account_email.header_subtitle") %>
            </div>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding:24px;">
            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:16px;line-height:24px;color:#0f172a;">
              <%= t("user_mailer.delete_account_email.greeting", name: @user_name) %>
            </div>

            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:15px;line-height:24px;color:#334155;margin-top:12px;">
              <%= t("user_mailer.delete_account_email.intro") %>
            </div>

            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:15px;line-height:24px;color:#334155;margin-top:12px;">
              <%= t("user_mailer.delete_account_email.cta_intro") %>
            </div>

            <!-- Button -->
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top:18px;margin-bottom:10px;">
              <tr>
                <td align="center" bgcolor="#2563eb" style="border-radius:10px;">
                  <a href="<%= @confirmation_link %>"
                     style="display:inline-block;padding:12px 18px;font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:15px;font-weight:700;line-height:20px;color:#ffffff;text-decoration:none;border-radius:10px;">
                    <%= t("user_mailer.delete_account_email.cta") %>
                  </a>
                </td>
              </tr>
            </table>

            <!-- Fallback link -->
            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:13px;line-height:20px;color:#64748b;margin-top:6px;">
              <%= t("user_mailer.delete_account_email.cta_fallback") %><br />
              <a href="<%= @confirmation_link %>" style="color:#2563eb;text-decoration:underline;word-break:break-all;">
                <%= @confirmation_link %>
              </a>
            </div>

            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:15px;line-height:24px;color:#334155;margin-top:18px;">
              <%= t("user_mailer.delete_account_email.permanent") %>
            </div>

            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:15px;line-height:24px;color:#334155;margin-top:12px;">
              <%= t("user_mailer.delete_account_email.expiry") %>
            </div>

            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:15px;line-height:24px;color:#334155;margin-top:18px;">
              <%= t("user_mailer.delete_account_email.ignore") %>
            </div>

            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:15px;line-height:24px;color:#334155;margin-top:12px;">
              <%= t("user_mailer.delete_account_email.contact_html", support_email: @support_email).html_safe %>
            </div>

            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:15px;line-height:24px;color:#334155;margin-top:18px;">
              <%= t("user_mailer.delete_account_email.thanks") %><br />
              <%= t("user_mailer.delete_account_email.signature") %>
            </div>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="padding:16px 24px;background:#f8fafc;border-top:1px solid #e7e7ef;">
            <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:12px;line-height:18px;color:#64748b;">
              <%= t("user_mailer.delete_account_email.footer") %>
            </div>
          </td>
        </tr>
      </table>

      <div style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;font-size:11px;line-height:16px;color:#94a3b8;margin-top:12px;">
        <%= t("user_mailer.delete_account_email.copyright_html", year: Time.current.year).html_safe %>
      </div>
    </td>
  </tr>
</table>

  </body>
</html>
