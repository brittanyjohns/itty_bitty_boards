<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= t("user_mailer.welcome_invitation_email.title") %></title>
  <style>
    body {
      background-color: #f4f4f4;
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 20px;
    }
    .container {
      background-color: #ffffff;
      max-width: 600px;
      margin: auto;
      padding: 30px 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .header {
      font-size: 24px;
      font-weight: bold;
      color: #333333;
      text-align: center;
      margin-bottom: 20px;
    }
    .content {
      font-size: 16px;
      color: #555555;
      line-height: 1.6;
    }
    .button {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 25px;
      background-color: #007bff;
      color: #ffffff !important;
      text-decoration: none;
      font-weight: bold;
      border-radius: 6px;
      font-size: 16px;
    }
    .footer {
      font-size: 14px;
      color: #888888;
      text-align: center;
      margin-top: 30px;
    }
    .logo img {
      max-width: 100px;
      height: auto;
      display: block;
      margin: 20px auto 0 auto;
    }
  </style>
</head>
<body>
  <div class="container">
    <a class="logo" href="https://www.speakanyway.com" target="_blank" rel="noopener">
      <%= image_tag @logo.url, alt: "SpeakAnyWay Logo" %>
    </a>
    <div class="header"><%= t("user_mailer.welcome_invitation_email.title") %></div>
    <div class="content">
      <p><%= t("user_mailer.welcome_invitation_email.intro_html", inviter_name: @inviter_name).html_safe %></p>
      <p><%= t("user_mailer.welcome_invitation_email.description") %></p>
      <p><%= t("user_mailer.welcome_invitation_email.cta_intro") %></p>
      <p style="text-align: center;">
        <a href="<%= @login_link %>" class="button"><%= t("user_mailer.welcome_invitation_email.cta") %></a>
      </p>
      <p><%= t("user_mailer.welcome_invitation_email.questions_html").html_safe %></p>
      <p><%= t("user_mailer.welcome_invitation_email.welcome_aboard") %></p>
      <p><%= t("user_mailer.welcome_invitation_email.signature") %></p>
    </div>
    <div class="footer">
      <%= t("user_mailer.welcome_invitation_email.copyright_html", year: Time.now.year).html_safe %>
    </div>
  </div>
</body>
</html>
