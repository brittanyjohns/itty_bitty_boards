<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title><%= t("user_mailer.temporary_login_email.title") %></title>
  </head>
  <body style="margin:0; padding:0; background:#f6f7f9; font-family: Arial, Helvetica, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center" style="padding:40px 16px;">
          <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px; background:#ffffff; border-radius:8px; padding:32px;">

            <tr>
              <td><%= render "layouts/email_logo" %></td>
            </tr>

            <tr>
              <td style="text-align:center;">
                <h1 style="margin:0 0 16px; font-size:22px; color:#222;">
                  <%= t("user_mailer.temporary_login_email.title") %>
                </h1>
              </td>
            </tr>

            <tr>
              <td style="font-size:15px; color:#444; line-height:1.6;">
                <p>
                  <%= @user.name.present? ? t("user_mailer.temporary_login_email.greeting_with_name", name: @user.name) : t("user_mailer.temporary_login_email.greeting_no_name") %>
                </p>

                <p>
                  <%= t("user_mailer.temporary_login_email.intro") %>
                </p>

                <p>
                  <%= t("user_mailer.temporary_login_email.instructions") %>
                </p>
              </td>
            </tr>

            <tr>
              <td align="center" style="padding:24px 0;">
                <a
                  href="<%= @login_link %>"
                  style="
                    background:#2abed1;
                    color:#ffffff;
                    text-decoration:none;
                    padding:14px 24px;
                    border-radius:6px;
                    font-size:16px;
                    font-weight:bold;
                    display:inline-block;
                  "
                >
                  <%= t("user_mailer.temporary_login_email.cta") %>
                </a>
              </td>
            </tr>

            <tr>
              <td style="font-size:14px; color:#555; line-height:1.6;">
                <p>
                  <%= t("user_mailer.temporary_login_email.link_info") %>
                </p>
                <ul style="padding-left:18px;">
                  <li><%= t("user_mailer.temporary_login_email.link_item_1") %></li>
                  <li><%= t("user_mailer.temporary_login_email.link_item_2", count: @expiration_hours) %></li>
                  <li><%= t("user_mailer.temporary_login_email.link_item_3") %></li>
                </ul>

                <p>
                  <%= t("user_mailer.temporary_login_email.ignore") %>
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding-top:24px; font-size:13px; color:#888; text-align:center;">
                <p style="margin:0;">
                  <%= t("user_mailer.temporary_login_email.signature") %>
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
