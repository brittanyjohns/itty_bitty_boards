<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= t("user_mailer.welcome_email.title") %></title>
  <meta name="color-scheme" content="light only">
  <style>
    body {
      background-color: #f7f9fc;
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 20px;
    }
    .container {
      background-color: #ffffff;
      margin: auto;
      max-width: 620px;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    }
    .logo img {
      max-width: 120px;
      display: block;
      margin: 0 auto 20px auto;
    }
    h1 {
      font-size: 26px;
      color: #2a2a2a;
      text-align: center;
      margin: 10px 0 6px 0;
    }
    .intro {
      font-size: 16px;
      color: #444444;
      line-height: 1.6;
      text-align: center;
      margin: 8px 0 22px 0;
      white-space: pre-line;
    }
    .button {
      display: inline-block;
      margin: 14px auto 0 auto;
      padding: 14px 28px;
      background-color: #7645ef;
      text-decoration: none;
      border-radius: 8px;
      color: #ffffff !important;
      font-weight: bold;
      font-size: 16px;
    }
    .subtext {
      font-size: 12px;
      color: #6b6b6b;
      text-align: center;
      margin-top: 8px;
    }
    .section {
      margin: 28px 0;
    }
    .section h2 {
      font-size: 18px;
      color: #2a2a2a;
      margin: 0 0 10px 0;
      text-align: left;
    }
    ul.check {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    ul.check li {
      margin: 10px 0;
      font-size: 15px;
      color: #555555;
      line-height: 1.5;
    }
    ul.check li::before {
      content: "✔";
      color: #2abed1;
      font-weight: 700;
      margin-right: 8px;
    }
    .quickstart {
      background: #f8ffef;
      border: 1px solid #d7f0b2;
      border-radius: 10px;
      padding: 16px;
    }
    .quickstart ol {
      margin: 8px 0 0 18px;
      padding: 0;
      color: #3f3f3f;
    }
    .quickstart li {
      margin: 8px 0;
      font-size: 15px;
      line-height: 1.5;
    }
    .footer {
      margin-top: 28px;
      font-size: 13px;
      text-align: center;
      color: #777777;
    }
    .footer a {
      color: #7645ef;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <!-- Preheader -->
  <div style="display:none;max-height:0;overflow:hidden;opacity:0;">
    <%= t("user_mailer.welcome_email.preheader") %>
  </div>

  <div class="container">
    <div class="logo">
      <a href="https://www.speakanyway.com" target="_blank" rel="noopener">
        <%= image_tag @logo.url, alt: "SpeakAnyWay Logo" %>
      </a>
    </div>

    <h1><%= t("user_mailer.welcome_email.title") %></h1>

    <p class="intro">
      <%= @user.name.blank? ? t("user_mailer.welcome_email.greeting_no_name") : t("user_mailer.welcome_email.greeting_with_name", name: @user.name) %>

      <%= t("user_mailer.welcome_email.intro") %>
    </p>

    <p style="text-align:center;">
      <a href="<%= @login_link %>" class="button"><%= t("user_mailer.welcome_email.cta") %></a>
    </p>

    <p class="subtext">
      <%= t("user_mailer.welcome_email.cta_fallback") %><br>
      <span style="word-break:break-all;color:#6b6b6b;"><%= @login_link %></span>
    </p>

    <div class="section">
      <h2><%= t("user_mailer.welcome_email.do_now_heading") %></h2>
      <ul class="check">
        <li><%= t("user_mailer.welcome_email.do_now_item_1") %></li>
        <li><%= t("user_mailer.welcome_email.do_now_item_2") %></li>
        <li><%= t("user_mailer.welcome_email.do_now_item_3") %></li>
      </ul>
    </div>

    <div class="section quickstart">
      <h2 style="margin:0 0 6px 0;"><%= t("user_mailer.welcome_email.quickstart_heading") %></h2>
      <ol>
        <li><%= t("user_mailer.welcome_email.quickstart_item_1") %></li>
        <li><%= t("user_mailer.welcome_email.quickstart_item_2") %></li>
        <li><%= t("user_mailer.welcome_email.quickstart_item_3") %></li>
      </ol>
    </div>

    <div class="section" style="text-align:center;">
      <p style="font-size:14px;color:#444;margin:0 0 6px 0;">
        <%= t("user_mailer.welcome_email.questions_html").html_safe %>
      </p>
    </div>

    <div class="footer">
      <p>
        <%= t("user_mailer.welcome_email.footer_thanks") %><br>
        <%= t("user_mailer.welcome_email.footer_signature") %>
      </p>
      <p>
        <a href="https://www.speakanyway.com" target="_blank"><%= t("user_mailer.welcome_email.footer_visit") %></a>
      </p>
    </div>
  </div>
</body>
</html>
