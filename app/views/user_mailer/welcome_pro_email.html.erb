<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title><%= t("user_mailer.welcome_pro_email.title") %></title>
  <meta name="color-scheme" content="light only">
  <style>
    body {
      background-color: #f6f8fb;
      font-family: Arial, sans-serif;
      color: #333;
      padding: 20px;
      margin: 0;
    }
    .container {
      max-width: 640px;
      background-color: #ffffff;
      padding: 30px;
      border-radius: 12px;
      margin: 0 auto;
      box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    }
    .logo img {
      max-width: 120px;
      display: block;
      margin: 0 auto 16px auto;
    }
    h1 {
      color: #111827;
      font-size: 26px;
      margin: 0 0 10px;
      text-align: center;
    }
    .subtitle {
      color: #4b5563;
      font-size: 15px;
      margin: 0 0 22px;
      text-align: center;
    }
    h2 {
      color: #1f2937;
      font-size: 18px;
      margin: 26px 0 10px;
    }
    p { line-height: 1.6; margin: 12px 0; }
    ul, ol { padding-left: 20px; margin: 10px 0; }
    li { margin: 6px 0; }

    .btn {
      display: inline-block;
      padding: 14px 24px;
      background-color: #2abed1;
      color: #000000 !important;
      text-decoration: none;
      font-weight: bold;
      border-radius: 8px;
      margin-top: 18px;
    }
    .muted {
      color: #6b7280;
      font-size: 13px;
    }
    .note {
      background: #f7f9fc;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 14px;
      font-size: 14px;
      color: #374151;
      margin-top: 16px;
    }
    .highlight {
      background: #ecfeff;
      border: 1px solid #67e8f9;
      border-radius: 10px;
      padding: 16px;
      margin: 18px 0;
    }
    .divider {
      height: 1px;
      background: #eef0f4;
      margin: 26px 0;
    }
    .footer {
      margin-top: 26px;
      font-size: 13px;
      color: #6b7280;
      text-align: left;
    }
    .footer a { color: #7645ef; text-decoration: none; }
  </style>
</head>
<body>
  <%# --- Dynamic limits (safe defaults) --- %>
  <% pro_price = (@pro_price || "$20/month") %>
  <% pro_comm_limit = (@pro_comm_limit || @user&.comm_account_limit || 5) %>

  <div class="container">
    <div class="logo">
      <a href="https://www.speakanyway.com" target="_blank" rel="noopener">
        <%= image_tag @logo.url, alt: "SpeakAnyWay Logo" %>
      </a>
    </div>

    <h1><%= t("user_mailer.welcome_pro_email.title") %></h1>
    <p class="subtitle">
      <%= t("user_mailer.welcome_pro_email.subtitle") %>
    </p>

    <p><%= @user.name.blank? ? t("user_mailer.welcome_pro_email.greeting_no_name") : t("user_mailer.welcome_pro_email.greeting_with_name", name: @user.name) %></p>

    <p>
      <%= t("user_mailer.welcome_pro_email.intro_html").html_safe %>
    </p>

    <!-- ⭐ LOANER COMMUNICATOR HIGHLIGHT -->
    <div class="highlight">
      <h2 style="margin-top:0;"><%= t("user_mailer.welcome_pro_email.loaner_heading") %></h2>
      <p>
        <%= t("user_mailer.welcome_pro_email.loaner_intro_html", count: pro_comm_limit).html_safe %>
      </p>

      <ul>
        <li><%= t("user_mailer.welcome_pro_email.loaner_item_1_html").html_safe %></li>
        <li><%= t("user_mailer.welcome_pro_email.loaner_item_2_html").html_safe %></li>
        <li><%= t("user_mailer.welcome_pro_email.loaner_item_3_html").html_safe %></li>
      </ul>

      <p class="muted">
        <%= t("user_mailer.welcome_pro_email.loaner_note") %>
      </p>
    </div>

    <h2><%= t("user_mailer.welcome_pro_email.included_heading") %></h2>
    <ul>
      <li><%= t("user_mailer.welcome_pro_email.included_paid_html", count: pro_comm_limit).html_safe %></li>
      <li><%= t("user_mailer.welcome_pro_email.included_demo_html").html_safe %></li>
      <li><%= t("user_mailer.welcome_pro_email.included_myspeak_html").html_safe %></li>
      <li><%= t("user_mailer.welcome_pro_email.included_supporters_html").html_safe %></li>
      <li><%= t("user_mailer.welcome_pro_email.included_ai_html").html_safe %></li>
      <li><%= t("user_mailer.welcome_pro_email.included_analytics_html").html_safe %></li>
      <li><%= t("user_mailer.welcome_pro_email.included_priority_html").html_safe %></li>
      <li><%= t("user_mailer.welcome_pro_email.included_pdf_html").html_safe %></li>
    </ul>

    <h2><%= t("user_mailer.welcome_pro_email.setup_heading") %></h2>
    <ol>
      <li><%= t("user_mailer.welcome_pro_email.setup_item_1") %></li>
      <li><%= t("user_mailer.welcome_pro_email.setup_item_2") %></li>
      <li><%= t("user_mailer.welcome_pro_email.setup_item_3") %></li>
      <li><%= t("user_mailer.welcome_pro_email.setup_item_4_html").html_safe %></li>
      <li><%= t("user_mailer.welcome_pro_email.setup_item_5") %></li>
    </ol>

    <p style="text-align:center;">
      <a href="<%= @login_link || @frontend_url %>" class="btn">
        <%= t("user_mailer.welcome_pro_email.cta") %>
      </a>
    </p>

    <p class="muted" style="text-align:center;">
      <%= t("user_mailer.welcome_pro_email.cta_fallback") %><br>
      <span style="word-break:break-all;">
        <%= @login_link || @frontend_url %>
      </span>
    </p>

    <div class="divider"></div>

    <h2><%= t("user_mailer.welcome_pro_email.tips_heading") %></h2>
    <ul>
      <li><%= t("user_mailer.welcome_pro_email.tips_item_1") %></li>
      <li><%= t("user_mailer.welcome_pro_email.tips_item_2") %></li>
      <li><%= t("user_mailer.welcome_pro_email.tips_item_3") %></li>
    </ul>

    <p class="footer">
      <%= t("user_mailer.welcome_pro_email.footer_help_html").html_safe %>
      <br><br>
      <%= t("user_mailer.welcome_pro_email.footer_pricing_html", pro_price: pro_price).html_safe %>
      <br><br>
      <%= t("user_mailer.welcome_pro_email.footer_signature") %>
    </p>
  </div>
</body>
</html>
