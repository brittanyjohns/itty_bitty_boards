<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= t("user_mailer.welcome_new_vendor_email.title", vendor_name: @vendor_name) %></title>
  <style>
    body {
      background-color: #f4f4f4;
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 20px;
    }
    .container {
      background-color: #ffffff;
      max-width: 600px;
      margin: auto;
      padding: 30px 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .header {
      font-size: 24px;
      font-weight: bold;
      color: #333333;
      text-align: center;
      margin-bottom: 20px;
    }
    .content {
      font-size: 16px;
      color: #555555;
      line-height: 1.6;
    }
    .button {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 25px;
      background-color: #007bff;
      color: #ffffff !important;
      text-decoration: none;
      font-weight: bold;
      border-radius: 6px;
      font-size: 16px;
    }
    .download-button {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 25px;
      background-color:rgb(50, 191, 130);
      color: #ffffff !important;
      text-decoration: none;
      font-weight: bold;
      border-radius: 6px;
      font-size: 16px;
    }
    .footer {
      font-size: 14px;
      color: #888888;
      text-align: center;
      margin-top: 30px;
    }
    .logo img {
      max-width: 100px;
      height: auto;
      display: block;
      margin: 20px auto 0 auto;
    }
  </style>
</head>
<body>
  <div class="container">
    <a class="logo" href="https://www.speakanyway.com" target="_blank" rel="noopener">
      <%= image_tag @logo.url, alt: "SpeakAnyWay Logo" %>
    </a>
    <div class="header"><%= t("user_mailer.welcome_new_vendor_email.title", vendor_name: @vendor_name) %></div>
    <div class="content">
      <p><%= t("user_mailer.welcome_new_vendor_email.intro_html", vendor_name: @vendor_name).html_safe %></p>

      <p><%= t("user_mailer.welcome_new_vendor_email.mission") %></p>

      <p><%= t("user_mailer.welcome_new_vendor_email.how_to") %></p>
      <div>
        <%= t("user_mailer.welcome_new_vendor_email.live_menu_html", menu_url: @menu_url).html_safe %>
        <a href="<%= @setup_url %>" class="download-button">
        <%= t("user_mailer.welcome_new_vendor_email.setup_cta") %>
        </a>
        <p><%= t("user_mailer.welcome_new_vendor_email.display_step") %></p>
        <p><%= t("user_mailer.welcome_new_vendor_email.community_step") %></p>
      </div>
      <p><%= t("user_mailer.welcome_new_vendor_email.dashboard_intro") %></p>
      <p><strong><%= t("user_mailer.welcome_new_vendor_email.dashboard_link_label") %></strong> <%= @menu_url %></p>

        <a href="<%= @login_link %>" class="button"><%= t("user_mailer.welcome_new_vendor_email.dashboard_cta") %></a>

      <p><%= t("user_mailer.welcome_new_vendor_email.help_html").html_safe %></p>

      <p><%= t("user_mailer.welcome_new_vendor_email.thanks") %></p>
      <p><%= t("user_mailer.welcome_new_vendor_email.signature") %></p>
    </div>
    <div class="footer">
      <%= t("user_mailer.welcome_new_vendor_email.copyright_html", year: Time.now.year).html_safe %>
    </div>
  </div>
</body>
</html>
