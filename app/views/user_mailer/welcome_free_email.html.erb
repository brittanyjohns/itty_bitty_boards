<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= t("user_mailer.welcome_free_email.title") %></title>
  <meta name="color-scheme" content="light only">
  <style>
    /* Email-safe, inline-friendly styles */
    body {
      background-color: #f7f9fc;
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 20px;
    }
    .container {
      background-color: #ffffff;
      margin: auto;
      max-width: 620px;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    }
    .logo img {
      max-width: 120px;
      display: block;
      margin: 0 auto 20px auto;
    }
    .badge {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      background: #eaf9fc;
      color: #2abed1;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .3px;
      text-transform: uppercase;
      margin: 0 auto 10px auto;
    }
    h1 {
      font-size: 26px;
      color: #2a2a2a;
      text-align: center;
      margin: 10px 0 6px 0;
    }
    .intro {
      font-size: 16px;
      color: #444444;
      line-height: 1.6;
      text-align: center;
      margin: 8px 0 22px 0;
      white-space: pre-line;
    }
    .button {
      display: inline-block;
      margin: 14px auto 0 auto;
      padding: 14px 28px;
      background-color: #7645ef;
      text-decoration: none;
      border-radius: 8px;
      color: #ffffff !important;
      font-weight: bold;
      font-size: 16px;
    }
    .subtext {
      font-size: 12px;
      color: #6b6b6b;
      text-align: center;
      margin-top: 8px;
    }
    .section {
      margin: 28px 0;
    }
    .section h2 {
      font-size: 18px;
      color: #2a2a2a;
      margin: 0 0 10px 0;
      text-align: left;
    }
    ul.check {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    ul.check li {
      margin: 10px 0;
      font-size: 15px;
      color: #555555;
      line-height: 1.5;
    }
    ul.check li::before {
      content: "✔";
      color: #2abed1;
      font-weight: 700;
      margin-right: 8px;
    }

    .quickstart {
      background: #f8ffef;
      border: 1px solid #d7f0b2;
      border-radius: 10px;
      padding: 16px;
    }
    .quickstart ol {
      margin: 8px 0 0 18px;
      padding: 0;
      color: #3f3f3f;
    }
    .quickstart li {
      margin: 8px 0;
      font-size: 15px;
      line-height: 1.5;
    }

    .compare {
      border: 1px solid #e9e9e9;
      border-radius: 12px;
      overflow: hidden;
    }
    /* legacy flex classes kept but not used for Gmail */
    .row { display: flex; border-top: 1px solid #e9e9e9; }
    .row:first-child { border-top: none; }
    .col { flex: 1; padding: 12px 14px; font-size: 14px; line-height: 1.4; }
    .head { background: #f7f9fc; font-weight: 700; color: #333; text-align: center; }
    .col + .col { border-left: 1px solid #e9e9e9; }
    .checkmark { color: #2abed1; font-weight: 700; }
    .dash { color: #bbb; }

    .upgrade-box {
      background-color: #f3edff;
      border: 1px solid #d6c8ff;
      border-radius: 10px;
      padding: 20px;
      margin: 25px 0 10px 0;
      text-align: center;
    }
    .upgrade-box h3 {
      margin: 0 0 8px 0;
      color: #7645ef;
      font-size: 18px;
    }
    .upgrade-box p {
      font-size: 14px;
      color: #444;
      line-height: 1.5;
      margin: 10px 0;
    }

    .footer {
      margin-top: 28px;
      font-size: 13px;
      text-align: center;
      color: #777777;
    }
    .footer a {
      color: #7645ef;
      text-decoration: none;
    }

    /* Keep links inside the compare table from turning Gmail-blue */
    .container table[role="presentation"] a { color:#333 !important; text-decoration:none !important; }

    /* Mobile tweaks */
    @media (max-width: 480px) {
      .container { padding: 22px; }
      h1 { font-size: 24px; }
      .row { display: block; }
      .col { border-left: none !important; border-top: 1px solid #e9e9e9; }
      .head .col { border-top: none; }
    }
  </style>
</head>
<body>
  <!-- Preheader (hidden preview text in inbox) -->
  <div style="display:none;max-height:0;overflow:hidden;opacity:0;">
    <%= t("user_mailer.welcome_free_email.preheader") %>
  </div>

  <div class="container">
    <div class="logo">
      <a href="https://www.speakanyway.com" target="_blank" rel="noopener">
        <%= image_tag @logo.url, alt: "SpeakAnyWay Logo" %>
      </a>
    </div>

    <div class="badge"><%= t("user_mailer.welcome_free_email.badge") %></div>
    <h1><%= t("user_mailer.welcome_free_email.title") %></h1>

    <p class="intro">
      <%= @user.name.blank? ? t("user_mailer.welcome_free_email.greeting_no_name") : t("user_mailer.welcome_free_email.greeting_with_name", name: @user.name) %>
      <%= t("user_mailer.welcome_free_email.intro_html").html_safe %>
    </p>

    <p style="text-align:center;">
      <a href="<%= @login_link %>" class="button"><%= t("user_mailer.welcome_free_email.cta") %></a>
    </p>
    <p class="subtext"><%= t("user_mailer.welcome_free_email.cta_fallback") %> <br><span style="word-break:break-all;color:#6b6b6b;"><%= @login_link %></span></p>

    <div class="section">
      <h2><%= t("user_mailer.welcome_free_email.do_now_heading") %></h2>
      <ul class="check">
        <li><%= t("user_mailer.welcome_free_email.do_now_item_1_html").html_safe %></li>
        <li><%= t("user_mailer.welcome_free_email.do_now_item_2") %></li>
        <li><%= t("user_mailer.welcome_free_email.do_now_item_3_html").html_safe %></li>
        <li><%= t("user_mailer.welcome_free_email.do_now_item_4") %></li>
      </ul>
    </div>

    <div class="section quickstart">
      <h2 style="margin:0 0 6px 0;"><%= t("user_mailer.welcome_free_email.quickstart_heading") %></h2>
      <ol>
        <li><%= t("user_mailer.welcome_free_email.quickstart_item_1_html").html_safe %></li>
        <li><%= t("user_mailer.welcome_free_email.quickstart_item_2") %></li>
        <li><%= t("user_mailer.welcome_free_email.quickstart_item_3") %></li>
      </ol>
    </div>

    <div class="section">
      <h2><%= t("user_mailer.welcome_free_email.myspeak_heading") %></h2>
      <p style="font-size:15px;color:#555;line-height:1.6;margin:0 0 12px;">
        <%= t("user_mailer.welcome_free_email.myspeak_intro_html").html_safe %>
      </p>
      <ul class="check">
        <li><%= t("user_mailer.welcome_free_email.myspeak_item_1_html").html_safe %></li>
        <li><%= t("user_mailer.welcome_free_email.myspeak_item_2_html").html_safe %></li>
        <li><%= t("user_mailer.welcome_free_email.myspeak_item_3_html").html_safe %></li>
      </ul>

      <div class="upgrade-box">
        <h3><%= t("user_mailer.welcome_free_email.upgrade_heading") %></h3>
        <p><%= t("user_mailer.welcome_free_email.upgrade_body") %></p>
        <p>
          <a href="https://www.speakanyway.com/pricing" class="button"><%= t("user_mailer.welcome_free_email.upgrade_cta") %></a>
        </p>
      </div>
    </div>

    <div class="section" style="text-align:center;">
      <p style="font-size:14px;color:#444;margin:0 0 6px 0;">
        <%= t("user_mailer.welcome_free_email.questions_html").html_safe %>
      </p>
    </div>

    <div class="footer">
      <p><%= t("user_mailer.welcome_free_email.footer_thanks") %><br><%= t("user_mailer.welcome_free_email.footer_signature") %></p>
      <p><a href="https://www.speakanyway.com" target="_blank"><%= t("user_mailer.welcome_free_email.footer_visit") %></a></p>
    </div>
  </div>
</body>
</html>
