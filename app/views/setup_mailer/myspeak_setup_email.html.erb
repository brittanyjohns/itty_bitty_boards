<!DOCTYPE html>
<html>
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <title><%= t("setup_mailer.myspeak_setup_email.title") %></title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f6f8fb;
        color: #333;
        padding: 20px;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 8px;
        padding: 30px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
      }
      .btn {
        display: inline-block;
        background-color:rgb(59, 246, 215);
        color:rgb(0, 0, 0);
        text-decoration: none;
        padding: 12px 20px;
        border-radius: 5px;
        font-weight: bold;
        margin-top: 20px;
      }
      h1 {
        color: #111827;
      }
      ul {
        padding-left: 20px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1><%= t("setup_mailer.myspeak_setup_email.title") %></h1>

      <p>
        <%= @user.name.blank? ? t("setup_mailer.myspeak_setup_email.greeting_no_name") : t("setup_mailer.myspeak_setup_email.greeting_with_name", name: @user.name) %>
      </p>

      <p><%= t("setup_mailer.myspeak_setup_email.intro") %></p>

      <h2><%= t("setup_mailer.myspeak_setup_email.getting_started_heading") %></h2>
      <ol>
        <li><%= t("setup_mailer.myspeak_setup_email.step_1_html", link: link_to(@frontend_url, @frontend_url)).html_safe %></li>
        <li><%= t("setup_mailer.myspeak_setup_email.step_2_html").html_safe %></li>
        <li><%= t("setup_mailer.myspeak_setup_email.step_3") %></li>
        <li><%= t("setup_mailer.myspeak_setup_email.step_4") %></li>
        <li><%= t("setup_mailer.myspeak_setup_email.step_5") %></li>
      </ol>

      <p><%= t("setup_mailer.myspeak_setup_email.outro") %></p>

      <a href="<%= @mymyspeak_link %>" class="btn"><%= t("setup_mailer.myspeak_setup_email.cta") %></a>

      <p style="margin-top: 30px;">
        <%= t("setup_mailer.myspeak_setup_email.support_html", support_url: "#{@frontend_url}support").html_safe %>
      </p>

      <p><%= t("setup_mailer.myspeak_setup_email.signoff") %><br/><%= t("setup_mailer.myspeak_setup_email.signature") %></p>
    </div>
  </body>
</html>
