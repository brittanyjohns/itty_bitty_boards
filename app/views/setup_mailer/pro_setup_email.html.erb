<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title><%= t("setup_mailer.pro_setup_email.title") %></title>
    <style>
      body {
        background-color: #f6f8fb;
        font-family: Arial, sans-serif;
        color: #333;
        padding: 20px;
      }
      .container {
        max-width: 640px;
        background-color: #ffffff;
        padding: 30px;
        border-radius: 8px;
        margin: 0 auto;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
      }
      h1 {
        color: #111827;
        font-size: 24px;
        margin-bottom: 20px;
      }
      h2 {
        color: #1f2937;
        font-size: 18px;
        margin-top: 30px;
      }
      .btn {
        display: inline-block;
        padding: 12px 20px;
        background-color:rgb(59, 246, 215);
        color:rgb(0, 0, 0);
        text-decoration: none;
        font-weight: bold;
        border-radius: 6px;
        margin-top: 20px;
      }
      ul, ol {
        padding-left: 20px;
      }
      p {
        line-height: 1.6;
      }
    </style>
  </head>
  <body>
    <div class="container">
  <%= render "layouts/email_logo" %>
      <h1><%= t("setup_mailer.pro_setup_email.title") %></h1>

      <p>
        <%= @user.name.blank? ? t("setup_mailer.pro_setup_email.greeting_no_name") : t("setup_mailer.pro_setup_email.greeting_with_name", name: @user.name) %>
      </p>

      <p><%= t("setup_mailer.pro_setup_email.intro_html").html_safe %></p>

      <h2><%= t("setup_mailer.pro_setup_email.included_heading") %></h2>
      <ul>
        <li><%= t("setup_mailer.pro_setup_email.included_item_1_html").html_safe %></li>
        <li><%= t("setup_mailer.pro_setup_email.included_item_2_html").html_safe %></li>
        <li><%= t("setup_mailer.pro_setup_email.included_item_3_html").html_safe %></li>
        <li><%= t("setup_mailer.pro_setup_email.included_item_4_html").html_safe %></li>
        <li><%= t("setup_mailer.pro_setup_email.included_item_5") %></li>
      </ul>

      <h2><%= t("setup_mailer.pro_setup_email.setup_heading") %></h2>
      <ol>
        <li><%= t("setup_mailer.pro_setup_email.setup_step_1_html", link: link_to(@frontend_url, @frontend_url)).html_safe %></li>
        <li><%= t("setup_mailer.pro_setup_email.setup_step_2_html").html_safe %></li>
        <li><%= t("setup_mailer.pro_setup_email.setup_step_3_html").html_safe %></li>
        <li><%= t("setup_mailer.pro_setup_email.setup_step_4") %></li>
        <li><%= t("setup_mailer.pro_setup_email.setup_step_5") %></li>
      </ol>

      <a href="<%= @frontend_url %>" class="btn"><%= t("setup_mailer.pro_setup_email.cta") %></a>

      <p style="margin-top: 30px;">
        <%= t("setup_mailer.pro_setup_email.support_html", support_url: "#{@frontend_url}/support").html_safe %>
      </p>

      <p><%= t("setup_mailer.pro_setup_email.signoff") %><br/><%= t("setup_mailer.pro_setup_email.signature") %></p>
    </div>
  </body>
</html>
