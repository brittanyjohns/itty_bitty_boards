<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <style>
      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        font-family: Inter, Arial, sans-serif;
        background: #ffffff;
        color: #0f172a;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      img {
        max-width: 100%;
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>