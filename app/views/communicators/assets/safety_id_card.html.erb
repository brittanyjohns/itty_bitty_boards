<div style="
  width:1200px;
  height:1800px;
  padding:34px;
  background:
    radial-gradient(circle at top right, rgba(139, 92, 246, 0.10) 0%, rgba(139, 92, 246, 0) 24%),
    radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.10) 0%, rgba(59, 130, 246, 0) 28%),
    linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
  color:#0f172a;
  position:relative;
  overflow:hidden;
">
  <div style="
    position:absolute;
    top:-80px;
    left:-70px;
    width:260px;
    height:260px;
    border-radius:999px;
    background:rgba(99, 102, 241, 0.06);
  "></div>

  <div style="
    position:absolute;
    bottom:-90px;
    right:-70px;
    width:280px;
    height:280px;
    border-radius:999px;
    background:rgba(139, 92, 246, 0.06);
  "></div>

  <div style="
    height:100%;
    border-radius:36px;
    background:rgba(255,255,255,0.98);
    border:1px solid rgba(226,232,240,0.95);
    box-shadow:
      0 24px 70px rgba(15, 23, 42, 0.10),
      0 8px 24px rgba(59, 130, 246, 0.05);
    overflow:hidden;
    position:relative;
    display:flex;
    flex-direction:column;
  ">
    <!-- Top band -->
    <div style="
      padding:24px 32px 24px 32px;
      background:
        linear-gradient(90deg, rgba(124, 58, 237, 0.98) 0%, rgba(99, 102, 241, 0.98) 45%, rgba(59, 130, 246, 0.98) 100%);
      color:white;
      position:relative;
      overflow:hidden;
    ">
      <div style="
        position:absolute;
        top:-30px;
        right:-20px;
        width:180px;
        height:180px;
        border-radius:999px;
        background:rgba(255,255,255,0.10);
      "></div>

      <div style="
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:24px;
        position:relative;
        z-index:2;
      ">
        <div style="display:flex; align-items:center; gap:18px;">
          <% if @logo.present? %>
            <img
              alt="SpeakAnyWay Logo"
              src="data:image/png;base64,<%= @logo %>"
              style="
                height:56px;
                width:auto;
                object-fit:contain;
                display:block;
              "
            />
          <% end %>

          <div>
            <div style="
              font-size:16px;
              font-weight:800;
              letter-spacing:0.12em;
              text-transform:uppercase;
              color:rgba(255,255,255,0.82);
              margin-bottom:6px;
            ">
              SpeakAnyWay
            </div>
            <div style="
              font-size:42px;
              font-weight:900;
              line-height:1.04;
              color:#ffffff;
            ">
              Safety ID Card
            </div>
          </div>
        </div>

        <div style="
          padding:12px 18px;
          border-radius:999px;
          background:rgba(255,255,255,0.14);
          border:1px solid rgba(255,255,255,0.20);
          font-size:15px;
          font-weight:800;
          color:#ffffff;
          white-space:nowrap;
        ">
          Important Communication & Safety Info
        </div>
      </div>
    </div>

    <!-- Body -->
    <div style="
      flex:1;
      padding:28px;
      display:grid;
      grid-template-columns: 1.7fr 0.95fr;
      gap:24px;
      min-height:0;
    ">
      <!-- LEFT COLUMN -->
      <div style="
        display:flex;
        flex-direction:column;
        gap:20px;
        min-height:0;
      ">
        <!-- Name / summary -->
        <div style="
          border-radius:28px;
          background:linear-gradient(180deg, #ffffff 0%, #fafcff 100%);
          border:1px solid #e2e8f0;
          padding:24px 24px 22px 24px;
          box-shadow:0 8px 20px rgba(15, 23, 42, 0.04);
        ">
          <div style="
            font-size:15px;
            font-weight:800;
            letter-spacing:0.10em;
            text-transform:uppercase;
            color:#64748b;
            margin-bottom:8px;
          ">
            Profile Name
          </div>

          <div style="
            font-size:54px;
            font-weight:900;
            line-height:1.02;
            color:#0f172a;
            word-break:break-word;
          ">
            <%= @display_name %>
          </div>
        </div>

        <!-- Emergency notes -->
        <div style="
          border-radius:30px;
          background:linear-gradient(180deg, #fff7f7 0%, #fff1f2 100%);
          border:2px solid #fecaca;
          padding:26px 26px 24px 26px;
          box-shadow:0 12px 26px rgba(239, 68, 68, 0.08);
        ">
          <div style="
            display:inline-flex;
            align-items:center;
            padding:10px 16px;
            border-radius:999px;
            background:rgba(239, 68, 68, 0.10);
            border:1px solid rgba(239, 68, 68, 0.16);
            color:#b91c1c;
            font-size:15px;
            font-weight:900;
            letter-spacing:0.06em;
            text-transform:uppercase;
            margin-bottom:14px;
          ">
            Emergency Notes
          </div>

          <div style="
            font-size:34px;
            line-height:1.28;
            color:#7f1d1d;
            font-weight:700;
          ">
            <%= @emergency_notes.presence || "Please scan the QR code for full communication and safety information." %>
          </div>
        </div>

        <!-- Emergency contacts -->
        <div style="
          border-radius:30px;
          background:#ffffff;
          border:1px solid #e2e8f0;
          padding:24px;
          box-shadow:0 8px 20px rgba(15, 23, 42, 0.04);
        ">
          <div style="
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:16px;
            margin-bottom:18px;
          ">
            <div style="
              font-size:28px;
              font-weight:900;
              color:#0f172a;
            ">
              Emergency Contacts
            </div>

            <div style="
              font-size:14px;
              font-weight:800;
              letter-spacing:0.08em;
              text-transform:uppercase;
              color:#64748b;
            ">
              Call First
            </div>
          </div>

          <% if @contacts.any? %>
            <% @contacts.each_with_index do |contact, index| %>
              <div style="
                border-top:<%= index == 0 ? 'none' : '1px solid #e2e8f0' %>;
                padding:<%= index == 0 ? '4px 0 0 0' : '18px 0 0 0' %>;
                margin-top:<%= index == 0 ? '0' : '18px' %>;
              ">
                <div style="
                  font-size:14px;
                  font-weight:800;
                  letter-spacing:0.08em;
                  text-transform:uppercase;
                  color:#64748b;
                  margin-bottom:8px;
                ">
                  <%= index == 0 ? "Primary Contact" : "Additional Contact #{index + 1}" %>
                </div>

                <div style="
                  font-size:34px;
                  font-weight:900;
                  line-height:1.1;
                  color:#0f172a;
                  margin-bottom:6px;
                ">
                  <%= contact["name"].presence || "—" %>
                </div>

                <div style="
                  font-size:28px;
                  font-weight:800;
                  color:#1d4ed8;
                  line-height:1.15;
                  margin-bottom:6px;
                ">
                  <%= contact["phone"].presence || "No phone listed" %>
                </div>

                <% if contact["relationship"].present? %>
                  <div style="
                    font-size:20px;
                    color:#475569;
                    line-height:1.3;
                  ">
                    <%= contact["relationship"] %>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div style="
              font-size:24px;
              color:#475569;
              line-height:1.4;
            ">
              No emergency contacts listed.
            </div>
          <% end %>
        </div>

        <!-- Medical grid -->
        <div style="
          display:grid;
          grid-template-columns:1fr 1fr;
          gap:18px;
        ">
          <div style="
            padding:22px;
            border-radius:26px;
            background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            border:1px solid #e2e8f0;
            min-height:190px;
          ">
            <div style="
              font-size:16px;
              font-weight:900;
              letter-spacing:0.08em;
              text-transform:uppercase;
              color:#7c3aed;
              margin-bottom:10px;
            ">
              Allergies
            </div>
            <div style="
              font-size:25px;
              line-height:1.38;
              color:#1e293b;
              font-weight:600;
            ">
              <%= @allergies.presence || "None listed" %>
            </div>
          </div>

          <div style="
            padding:22px;
            border-radius:26px;
            background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            border:1px solid #e2e8f0;
            min-height:190px;
          ">
            <div style="
              font-size:16px;
              font-weight:900;
              letter-spacing:0.08em;
              text-transform:uppercase;
              color:#2563eb;
              margin-bottom:10px;
            ">
              Medical Conditions
            </div>
            <div style="
              font-size:25px;
              line-height:1.38;
              color:#1e293b;
              font-weight:600;
            ">
              <%= @medical_conditions.presence || "None listed" %>
            </div>
          </div>

          <div style="
            padding:22px;
            border-radius:26px;
            background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            border:1px solid #e2e8f0;
            min-height:190px;
          ">
            <div style="
              font-size:16px;
              font-weight:900;
              letter-spacing:0.08em;
              text-transform:uppercase;
              color:#0f766e;
              margin-bottom:10px;
            ">
              Medications
            </div>
            <div style="
              font-size:25px;
              line-height:1.38;
              color:#1e293b;
              font-weight:600;
            ">
              <%= @medications.presence || "None listed" %>
            </div>
          </div>

          <div style="
            padding:22px;
            border-radius:26px;
            background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            border:1px solid #e2e8f0;
            min-height:190px;
          ">
            <div style="
              font-size:16px;
              font-weight:900;
              letter-spacing:0.08em;
              text-transform:uppercase;
              color:#ea580c;
              margin-bottom:10px;
            ">
              Other Conditions
            </div>
            <div style="
              font-size:25px;
              line-height:1.38;
              color:#1e293b;
              font-weight:600;
            ">
              <%= @other_conditions.presence || "None listed" %>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div style="
        display:flex;
        flex-direction:column;
        gap:20px;
      ">
        <!-- Avatar card -->
        <div style="
          border-radius:30px;
          background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
          border:1px solid #e2e8f0;
          padding:24px;
          text-align:center;
          box-shadow:0 8px 20px rgba(15, 23, 42, 0.04);
        ">
          <div style="
            margin-bottom:16px;
            display:flex;
            justify-content:center;
          ">
            <div style="
              padding:10px;
              border-radius:999px;
              background:linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%);
              box-shadow:0 12px 28px rgba(99, 102, 241, 0.16);
            ">
              <% if @avatar_data_url.present? %>
                <img
                  src="<%= @avatar_data_url %>"
                  style="
                    width:190px;
                    height:190px;
                    border-radius:999px;
                    object-fit:cover;
                    display:block;
                    border:6px solid #ffffff;
                    background:#eef2ff;
                  "
                />
              <% else %>
                <div style="
                  width:190px;
                  height:190px;
                  border-radius:999px;
                  background:linear-gradient(135deg, #e9d5ff 0%, #dbeafe 100%);
                  border:6px solid #ffffff;
                "></div>
              <% end %>
            </div>
          </div>

          <div style="
            font-size:15px;
            font-weight:800;
            letter-spacing:0.08em;
            text-transform:uppercase;
            color:#64748b;
            margin-bottom:8px;
          ">
            Safety Profile
          </div>

          <div style="
            font-size:32px;
            font-weight:900;
            line-height:1.12;
            color:#0f172a;
            word-break:break-word;
          ">
            <%= @display_name %>
          </div>
        </div>

        <!-- QR card -->
        <div style="
          border-radius:30px;
          background:
            linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,250,252,0.98) 100%);
          border:1px solid #e2e8f0;
          padding:24px;
          text-align:center;
          box-shadow:0 8px 20px rgba(15, 23, 42, 0.04);
        ">
          <div style="
            font-size:15px;
            font-weight:900;
            letter-spacing:0.10em;
            text-transform:uppercase;
            color:#64748b;
            margin-bottom:12px;
          ">
            Scan Profile
          </div>

          <% if @qr_data_url.present? %>
            <div style="
              display:inline-block;
              padding:16px;
              border-radius:24px;
              background:#ffffff;
              border:1px solid #e2e8f0;
              box-shadow:0 12px 24px rgba(15, 23, 42, 0.08);
              margin-bottom:14px;
            ">
              <img
                src="<%= @qr_data_url %>"
                style="
                  width:250px;
                  height:250px;
                  display:block;
                "
              />
            </div>
          <% else %>
            <div style="
              width:282px;
              height:282px;
              margin:0 auto 14px auto;
              border-radius:24px;
              background:linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
              border:1px solid #e2e8f0;
            "></div>
          <% end %>

          <div style="
            font-size:24px;
            font-weight:900;
            line-height:1.18;
            color:#0f172a;
            margin-bottom:8px;
          ">
            Scan for full safety profile
          </div>

          <div style="
            font-size:18px;
            line-height:1.38;
            color:#64748b;
          ">
            Opens their public SpeakAnyWay profile with communication and emergency information.
          </div>
        </div>

        <!-- Footer info block -->
        <div style="
          margin-top:auto;
          border-radius:26px;
          background:linear-gradient(135deg, rgba(124, 58, 237, 0.08) 0%, rgba(59, 130, 246, 0.08) 100%);
          border:1px solid rgba(99, 102, 241, 0.12);
          padding:20px 22px;
        ">
          <div style="
            font-size:15px;
            font-weight:900;
            letter-spacing:0.08em;
            text-transform:uppercase;
            color:#64748b;
            margin-bottom:10px;
          ">
            Helpful Note
          </div>

          <div style="
            font-size:21px;
            line-height:1.42;
            color:#334155;
            font-weight:600;
          ">
            Keep this card accessible for caregivers, school staff, therapists, and emergency responders.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>