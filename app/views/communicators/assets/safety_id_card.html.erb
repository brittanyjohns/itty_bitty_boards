<!-- app/views/communicators/assets/safety_id_card.html.erb -->
<div style="width:1200px; height:1800px; padding:48px; background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%); color:#0f172a;">
  <div style="height:100%; border: 4px solid #e2e8f0; border-radius: 32px; background: white; padding: 40px; display:flex; flex-direction:column;">
    <div style="display:flex; align-items:center; gap:28px; margin-bottom:32px;">
      <% if avatar_data_url.present? %>
        <img src="<%= avatar_data_url %>" style="width:150px; height:150px; border-radius:999px; object-fit:cover; border: 4px solid #e2e8f0;" />
      <% else %>
        <div style="width:150px; height:150px; border-radius:999px; background:#e2e8f0;"></div>
      <% end %>

      <div>
        <div style="font-size:28px; color:#475569; margin-bottom:8px;">Safety Information</div>
        <div style="font-size:56px; font-weight:800; line-height:1.05;"><%= display_name %></div>
      </div>
    </div>

    <div style="padding:28px; background:#fef2f2; border: 2px solid #fecaca; border-radius:24px; margin-bottom:24px;">
      <div style="font-size:24px; font-weight:700; margin-bottom:10px;">Emergency Notes</div>
      <div style="font-size:32px; line-height:1.35;"><%= emergency_notes %></div>
    </div>

    <div style="padding:28px; background:#f8fafc; border: 2px solid #e2e8f0; border-radius:24px; margin-bottom:24px;">
      <div style="font-size:24px; font-weight:700; margin-bottom:18px;">Emergency Contacts</div>

      <% if contacts.any? %>
        <% contacts.each_with_index do |contact, index| %>
          <div style="padding:18px 0; border-top:<%= index == 0 ? 'none' : '1px solid #cbd5e1' %>;">
            <div style="font-size:18px; color:#64748b; margin-bottom:6px;">
              <%= index == 0 ? "Primary Contact" : "Additional Contact #{index + 1}" %>
            </div>
            <div style="font-size:30px; font-weight:700;"><%= contact["name"].presence || "—" %></div>
            <div style="font-size:24px; margin-top:4px;"><%= contact["phone"].presence || "No phone listed" %></div>
            <% if contact["relationship"].present? %>
              <div style="font-size:20px; color:#475569; margin-top:4px;"><%= contact["relationship"] %></div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div style="font-size:24px;">No emergency contacts listed.</div>
      <% end %>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:auto;">
      <div style="padding:24px; background:#f8fafc; border: 2px solid #e2e8f0; border-radius:24px;">
        <div style="font-size:22px; font-weight:700; margin-bottom:8px;">Allergies</div>
        <div style="font-size:24px; line-height:1.4;"><%= allergies %></div>
      </div>

      <div style="padding:24px; background:#f8fafc; border: 2px solid #e2e8f0; border-radius:24px;">
        <div style="font-size:22px; font-weight:700; margin-bottom:8px;">Medical Conditions</div>
        <div style="font-size:24px; line-height:1.4;"><%= medical_conditions %></div>
      </div>

      <div style="padding:24px; background:#f8fafc; border: 2px solid #e2e8f0; border-radius:24px;">
        <div style="font-size:22px; font-weight:700; margin-bottom:8px;">Medications</div>
        <div style="font-size:24px; line-height:1.4;"><%= medications %></div>
      </div>

      <div style="padding:24px; background:#f8fafc; border: 2px solid #e2e8f0; border-radius:24px;">
        <div style="font-size:22px; font-weight:700; margin-bottom:8px;">Other Conditions</div>
        <div style="font-size:24px; line-height:1.4;"><%= other_conditions %></div>
      </div>
    </div>
    <% if qr_data_url.present? %>
    <div style="margin-top:40px; text-align:center;">
        <img src="<%= qr_data_url %>" style="width:260px; height:260px;" />
        <div style="font-size:20px; margin-top:12px; color:#475569;">
        Scan for full safety profile
        </div>
    </div>
    <% end %>
  </div>
</div>