<div style="
  width:1200px;
  height:700px;
  padding:26px;
  background:
    radial-gradient(circle at top left, rgba(168, 85, 247, 0.18) 0%, rgba(168, 85, 247, 0) 28%),
    radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.18) 0%, rgba(59, 130, 246, 0) 30%),
    linear-gradient(135deg, #f8fbff 0%, #fdfaff 50%, #f7fbff 100%);
  color:#1e293b;
  position:relative;
  overflow:hidden;
">
  <div style="
    position:absolute;
    top:-70px;
    right:-50px;
    width:220px;
    height:220px;
    border-radius:999px;
    background:rgba(139, 92, 246, 0.08);
  "></div>

  <div style="
    position:absolute;
    bottom:-80px;
    left:-60px;
    width:240px;
    height:240px;
    border-radius:999px;
    background:rgba(59, 130, 246, 0.08);
  "></div>

  <div style="
    height:100%;
    border-radius:34px;
    background:linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,250,252,0.98) 100%);
    border:1px solid rgba(226,232,240,0.9);
    box-shadow:
      0 22px 60px rgba(15, 23, 42, 0.10),
      0 8px 24px rgba(139, 92, 246, 0.08);
    padding:26px 28px 24px 28px;
    display:flex;
    flex-direction:column;
    position:relative;
    overflow:hidden;
  ">
    <div style="
      position:absolute;
      top:0;
      left:0;
      right:0;
      height:10px;
      background:linear-gradient(90deg, #8b5cf6 0%, #6366f1 45%, #3b82f6 100%);
    "></div>

    <!-- Header -->
    <div style="
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
      padding-top:8px;
      margin-bottom:18px;
    ">
      <div style="display:flex; align-items:center; gap:16px;">
        <% if @logo.present? %>
          <img
            alt="SpeakAnyWay Logo"
            src="data:image/png;base64,<%= @logo %>"
            style="
              height:48px;
              width:auto;
              object-fit:contain;
              display:block;
            "
          />
        <% end %>

        <div>
          <div style="
            font-size:15px;
            font-weight:700;
            letter-spacing:0.12em;
            text-transform:uppercase;
            color:#7c3aed;
            margin-bottom:4px;
          ">
            SpeakAnyWay™
          </div>
          <div style="
            font-size:26px;
            font-weight:800;
            color:#0f172a;
            line-height:1.1;
          ">
            Communication Device Tag
          </div>
        </div>
      </div>

      <div style="
        padding:10px 16px;
        border-radius:999px;
        background:linear-gradient(135deg, rgba(139, 92, 246, 0.12) 0%, rgba(59, 130, 246, 0.12) 100%);
        border:1px solid rgba(139, 92, 246, 0.16);
        font-size:14px;
        font-weight:700;
        color:#475569;
        white-space:nowrap;
      ">
        Keep me close, Keep me charged ⚡
      </div>
    </div>

    <!-- Main content -->
    <div style="
      flex:1;
      display:grid;
      grid-template-columns: 1.25fr 1.55fr 0.95fr;
      gap:18px;
      align-items:stretch;
      min-height:0;
    ">
      <!-- Left -->
      <div style="
        border-radius:28px;
        background:linear-gradient(180deg, rgba(255,255,255,0.92) 0%, rgba(248,250,252,0.96) 100%);
        border:1px solid #e2e8f0;
        padding:22px 18px;
        display:flex;
        flex-direction:column;
        align-items:center;
        justify-content:center;
        text-align:center;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
      ">
        <div style="
          padding:8px;
          border-radius:999px;
          background:linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%);
          box-shadow:0 10px 24px rgba(99, 102, 241, 0.18);
          margin-bottom:16px;
        ">
          <% if @avatar_data_url.present? %>
            <img
              src="<%= @avatar_data_url %>"
              style="
                width:178px;
                height:178px;
                border-radius:999px;
                object-fit:cover;
                display:block;
                border:6px solid #ffffff;
                background:#eef2ff;
              "
            />
          <% else %>
            <div style="
              width:178px;
              height:178px;
              border-radius:999px;
              background:linear-gradient(135deg, #e9d5ff 0%, #dbeafe 100%);
              border:6px solid #ffffff;
            "></div>
          <% end %>
        </div>

        <div style="
          font-size:15px;
          font-weight:700;
          letter-spacing:0.08em;
          text-transform:uppercase;
          color:#64748b;
          margin-bottom:8px;
        ">
          This device belongs to
        </div>

        <div style="
          font-size:36px;
          font-weight:900;
          line-height:1.08;
          color:#0f172a;
          word-break:break-word;
        ">
          <%= @display_name %>
        </div>
      </div>

      <!-- Middle -->
      <div style="
        border-radius:28px;
        background:#ffffff;
        border:1px solid #e2e8f0;
        padding:22px 22px 20px 22px;
        display:flex;
        flex-direction:column;
        justify-content:space-between;
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.7),
          0 8px 20px rgba(15, 23, 42, 0.04);
      ">
        <div>
          <div style="
            display:inline-flex;
            align-items:center;
            gap:8px;
            padding:9px 14px;
            border-radius:999px;
            background:rgba(239, 68, 68, 0.10);
            border:1px solid rgba(239, 68, 68, 0.15);
            color:#b91c1c;
            font-size:15px;
            font-weight:800;
            letter-spacing:0.04em;
            text-transform:uppercase;
            margin-bottom:14px;
          ">
            Important
          </div>

          <div style="
            font-size:20px;
            line-height:1.22;
            color:#1e293b;
            font-weight:400;
            margin-bottom:18px;
          ">
            <%= @device_notes.presence || "This device is my voice. Please use it to help me communicate and access important information in any situation." %>
          </div>
        </div>

        <div style="
          margin-top:10px;
          padding:18px 18px 16px 18px;
          border-radius:22px;
          background:linear-gradient(135deg, rgba(139, 92, 246, 0.08) 0%, rgba(59, 130, 246, 0.08) 100%);
          border:1px solid rgba(99, 102, 241, 0.14);
        ">
          <div style="
            font-size:14px;
            font-weight:800;
            letter-spacing:0.10em;
            text-transform:uppercase;
            color:#64748b;
            margin-bottom:8px;
          ">
            Emergency Contact
          </div>

          <div style="
            font-size:28px;
            font-weight:800;
            color:#0f172a;
            line-height:1.15;
            margin-bottom:8px;
          ">
            <%= @primary_contact_name.presence || "Emergency Contact" %>
          </div>

          <div style="
            font-size:36px;
            font-weight:900;
            color:#7c2d12;
            line-height:1.05;
            letter-spacing:0.01em;
          ">
            <%= @primary_contact_phone.presence || "No phone listed" %>
          </div>
        </div>
      </div>

      <!-- Right -->
      <div style="
        border-radius:28px;
        background:linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,250,252,0.98) 100%);
        border:1px solid #e2e8f0;
        padding:18px 16px;
        display:flex;
        flex-direction:column;
        align-items:center;
        justify-content:center;
        text-align:center;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
      ">
        <div style="
          font-size:14px;
          font-weight:800;
          letter-spacing:0.11em;
          text-transform:uppercase;
          color:#64748b;
          margin-bottom:10px;
        ">
          Scan Me
        </div>

        <% if @qr_data_url.present? %>
          <div style="
            padding:14px;
            background:#ffffff;
            border-radius:22px;
            border:1px solid #e2e8f0;
            box-shadow:0 10px 24px rgba(15, 23, 42, 0.08);
            margin-bottom:14px;
          ">
            <img
              src="<%= @qr_data_url %>"
              style="
                width:210px;
                height:210px;
                display:block;
              "
            />
          </div>
        <% else %>
          <div style="
            width:238px;
            height:238px;
            border-radius:22px;
            background:linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
            border:1px solid #e2e8f0;
            margin-bottom:14px;
          "></div>
        <% end %>

        <div style="
          font-size:22px;
          font-weight:900;
          color:#0f172a;
          line-height:1.15;
          margin-bottom:8px;
        ">
          Scan to Understand
        </div>

        <div style="
          font-size:14px;
          line-height:1.25;
          color:#64748b;
          max-width:220px;
        ">
            Access communication tools, safety information, and emergency contacts from this device to help me communicate in any situation.
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div style="
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      margin-top:16px;
      padding:12px 4px 0 4px;
    ">
      <div style="
        font-size:15px;
        color:#64748b;
        font-weight:600;
      ">
        This QR code contains important communication and safety information. Please scan with your phone to view.
      </div>

      <div style="
        font-size:14px;
        color:#94a3b8;
        font-weight:700;
        letter-spacing:0.06em;
        text-transform:uppercase;
      ">
        SpeakAnyWay
      </div>
    </div>
  </div>
</div>